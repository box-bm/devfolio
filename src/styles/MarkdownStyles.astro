<style is:global>
  /* ================================================
     Markdown Content Styles
     Scoped to main to avoid polluting other layouts.
     Uses CSS custom properties from GlobalStyles.astro
     ================================================ */

  main .markdown-body {
    max-width: 72ch;
    margin: 0 auto;
    padding: 24px 16px 48px;
    line-height: 1.75;
    color: var(--text-primary);
  }

  /* ---------- Headings ---------- */
  main .markdown-body h1,
  main .markdown-body h2,
  main .markdown-body h3,
  main .markdown-body h4,
  main .markdown-body h5,
  main .markdown-body h6 {
    margin-top: 2rem !important;
    margin-bottom: 0.75rem !important;
    color: var(--text-primary);
    font-family: "Bitter", serif;
    font-weight: 600;
  }

  main .markdown-body h1 { font-size: 2.25rem; line-height: 2.75rem; }
  main .markdown-body h2 { font-size: 1.75rem; line-height: 2.25rem; }
  main .markdown-body h3 { font-size: 1.375rem; line-height: 1.875rem; }
  main .markdown-body h4 { font-size: 1.125rem; line-height: 1.625rem; }
  main .markdown-body h5 { font-size: 1rem;     line-height: 1.5rem; }
  main .markdown-body h6 { font-size: 0.875rem; line-height: 1.25rem; color: var(--text-secondary); }

  /* ---------- Paragraphs ---------- */
  main .markdown-body p {
    margin-top: 0;
    margin-bottom: 1.25rem;
    color: var(--text-primary);
  }

  /* ---------- Links ---------- */
  main .markdown-body a:not(.btn) {
    color: var(--accent-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  main .markdown-body a:not(.btn):hover {
    color: var(--accent-dark);
  }

  /* ---------- Lists ---------- */
  main .markdown-body ul,
  main .markdown-body ol {
    margin-top: 0;
    margin-bottom: 1.25rem;
    padding-left: 1.75rem;
    color: var(--text-primary);
  }

  main .markdown-body ul {
    list-style-type: disc;
  }

  main .markdown-body ul ul {
    list-style-type: circle;
    margin-bottom: 0;
  }

  main .markdown-body ul ul ul {
    list-style-type: square;
  }

  main .markdown-body ol {
    list-style-type: decimal;
  }

  main .markdown-body ol ol {
    list-style-type: lower-alpha;
    margin-bottom: 0;
  }

  main .markdown-body li {
    margin-bottom: 0.375rem;
    color: var(--text-primary);
  }

  main .markdown-body li::marker {
    color: var(--accent-primary);
  }

  /* ---------- Inline Code ---------- */
  main .markdown-body code:not(pre code) {
    background-color: var(--neutral-light);
    color: var(--accent-primary);
    border: 1px solid var(--neutral-medium);
    border-radius: 4px;
    padding: 0.15em 0.45em;
    font-size: 0.875em;
    font-family: "Courier New", Courier, monospace;
    white-space: nowrap;
  }

  [data-theme="dark"] main .markdown-body code:not(pre code) {
    background-color: var(--neutral-light-gray);
    color: #93c5fd; /* blue-300 — readable on dark */
    border-color: var(--neutral-medium);
  }

  /* ---------- Code Blocks ----------
     Shiki emits CSS variables (--shiki-light / --shiki-dark) when dual
     themes are configured. We switch which set is active via [data-theme].
  ----------------------------------------- */
  main .markdown-body pre,
  main .markdown-body pre span {
    color: var(--shiki-light);
    background-color: var(--shiki-light-bg);
  }

  [data-theme="dark"] main .markdown-body pre,
  [data-theme="dark"] main .markdown-body pre span {
    color: var(--shiki-dark) !important;
    background-color: var(--shiki-dark-bg) !important;
  }

  main .markdown-body pre {
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
    line-height: 1.65;
    border: 1px solid var(--neutral-medium);
  }

  [data-theme="dark"] main .markdown-body pre {
    border-color: var(--neutral-medium);
  }

  main .markdown-body pre code {
    background: none !important;
    border: none;
    padding: 0;
    font-size: inherit;
    white-space: pre;
  }

  /* ---------- Blockquotes ---------- */
  main .markdown-body blockquote {
    border-left: 4px solid var(--accent-primary);
    margin: 0 0 1.25rem 0;
    padding: 0.75rem 1.25rem;
    background-color: var(--neutral-light);
    border-radius: 0 6px 6px 0;
    color: var(--text-secondary);
    font-style: italic;
  }

  [data-theme="dark"] main .markdown-body blockquote {
    background-color: var(--neutral-light-gray);
    color: var(--text-secondary);
  }

  main .markdown-body blockquote p {
    margin-bottom: 0;
    color: inherit;
  }

  /* ---------- Tables ---------- */
  main .markdown-body table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.9375rem;
    overflow-x: auto;
    display: block;
  }

  main .markdown-body thead {
    background-color: var(--neutral-light);
    border-bottom: 2px solid var(--accent-primary);
  }

  [data-theme="dark"] main .markdown-body thead {
    background-color: var(--neutral-light-gray);
  }

  main .markdown-body th {
    padding: 0.75rem 1rem;
    text-align: left;
    font-weight: 600;
    color: var(--text-primary);
    white-space: nowrap;
  }

  main .markdown-body td {
    padding: 0.625rem 1rem;
    color: var(--text-primary);
    border-bottom: 1px solid var(--neutral-light-gray);
  }

  [data-theme="dark"] main .markdown-body td {
    border-bottom-color: var(--neutral-medium);
  }

  main .markdown-body tbody tr:nth-child(even) {
    background-color: var(--neutral-light);
  }

  [data-theme="dark"] main .markdown-body tbody tr:nth-child(even) {
    background-color: var(--neutral-light-gray);
  }

  main .markdown-body tbody tr:hover {
    background-color: var(--neutral-medium);
    transition: background-color 150ms ease;
  }

  /* ---------- Horizontal Rule ---------- */
  main .markdown-body hr {
    border: none;
    border-top: 1px solid var(--neutral-medium);
    margin: 2rem 0;
  }

  /* ---------- Images ---------- */
  main .markdown-body img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
    margin: 1.5rem auto;
  }

  /* ---------- Strong / Em / Del ---------- */
  main .markdown-body strong {
    font-weight: 700;
    color: var(--text-primary);
  }

  main .markdown-body em {
    font-style: italic;
    color: var(--text-primary);
  }

  main .markdown-body del {
    color: var(--text-secondary);
    text-decoration: line-through;
  }

  /* ---------- Details / Summary ---------- */
  main .markdown-body details {
    border: 1px solid var(--neutral-medium);
    border-radius: 6px;
    padding: 0.5rem 1rem;
    margin-bottom: 1.25rem;
    background-color: var(--neutral-light);
  }

  [data-theme="dark"] main .markdown-body details {
    background-color: var(--neutral-light-gray);
  }

  main .markdown-body summary {
    cursor: pointer;
    font-weight: 600;
    color: var(--text-primary);
    padding: 0.25rem 0;
  }

  main .markdown-body details[open] summary {
    margin-bottom: 0.75rem;
  }
</style>
